# === Required ===

# PostgreSQL connection (Railway provides this automatically when you add a Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Anthropic API key for Claude (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CORS: your frontend URL (GitHub Pages URL once deployed)
ALLOWED_ORIGINS=https://yourusername.github.io,http://localhost:8080

# === Optional ===

# Claude model (defaults to sonnet; can swap to haiku for cheaper runs)
CLAUDE_MODEL=claude-sonnet-4-6

# Scraping config
SCRAPER_TARGET_CITY=Montreal
SCRAPER_SEARCH_TERMS=peintre,painter,CCQ
SCRAPER_MAX_PAGES=5

# Admin password (simple gate for review queue page)
ADMIN_PASSWORD=change-this-to-something-strong

# Google Maps API key (for the map view — optional, falls back to OpenStreetMap)
GOOGLE_MAPS_API_KEY=
